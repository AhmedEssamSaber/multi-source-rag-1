GROQ_API_KEY=your_groq_api_key_here

# ── Groq Model (optional) ───────────────────────────
# llama-3.3-70b-versatile | llama3-8b-8192 | gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile
